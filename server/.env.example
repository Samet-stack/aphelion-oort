PORT=3001

# PostgreSQL Supabase (Session pooler recommande)
# Exemple:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=

JWT_SECRET=change-me-very-strong-secret

# Frontend URL pour les liens email
FRONTEND_URL=http://localhost:5173

# Production settings
# - AUTO_INIT_DB: if true, runs `supabase/siteflow_schema.sql` on server startup.
#   Recommended: keep false in production/serverless and run `npm run init-db` manually.
AUTO_INIT_DB=false

# - VERIFY_SMTP: if true, checks SMTP connectivity on startup (optional).
VERIFY_SMTP=false

# SMTP (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@siteflow.pro
