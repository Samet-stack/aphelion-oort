PORT=3001

# PostgreSQL Supabase (Session pooler recommande)
# Exemple:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=

JWT_SECRET=change-me-very-strong-secret

# Frontend URL pour les liens email
FRONTEND_URL=http://localhost:5173

# Production settings
# - AUTO_INIT_DB: if true, runs `supabase/siteflow_schema.sql` on server startup.
#   Recommended: keep false in production/serverless and run `npm run init-db` manually.
AUTO_INIT_DB=false

# - VERIFY_SMTP: if true, checks SMTP connectivity on startup (optional).
VERIFY_SMTP=false

# Cache (Redis en production, fallback mémoire en local)
# CACHE_MODE = auto | redis | memory | off
CACHE_MODE=auto
REDIS_URL=
CACHE_PREFIX=siteflow
CACHE_TTL_REPORTS_SECONDS=90
CACHE_TTL_REPORT_DETAIL_SECONDS=120
CACHE_TTL_REPORT_STATS_SECONDS=90
CACHE_TTL_SITES_SECONDS=90
CACHE_TTL_SITE_DETAIL_SECONDS=120
CACHE_TTL_PLANS_SECONDS=90
CACHE_TTL_PLAN_DETAIL_SECONDS=120

# Logging / observabilité
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=./logs

# SMTP (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@siteflow.pro

# Google Gemini AI (optionnel mais recommandé)
# Obtenez votre clé sur: https://aistudio.google.com/app/apikey
# La clé reste côté serveur (sécurisée), jamais exposée au client
GEMINI_API_KEY=
