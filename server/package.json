{
  "name": "siteflow-api",
  "version": "1.0.0",
  "description": "API SiteFlow Pro - Gestion des rapports de chantier",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node init-db.js",
    "test": "vitest",
